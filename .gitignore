huan-ui/user/characters/*/channel_directory.json
huan-ui/user/characters/*/processes.json
huan-ui/user/characters/*/state.db
huan-ui/user/characters/*/state.db-shm
huan-ui/user/characters/*/state.db-wal
huan-ui/user/characters/*/.skills_prompt_snapshot.json
huan-ui/user/characters/*/.update_check
huan-ui/user/characters/*/interrupt_debug.log
huan-ui/user/characters/*/memories/
huan-ui/user/characters/*/sessions/
huan-ui/user/characters/*/logs/
huan-ui/user/characters/*/cache/
huan-ui/user/characters/*/bin/
