# ── Runtime / user data (contains API keys, personal data, sessions) ──────────
# Exclude all user runtime data except the static character definitions
huan-ui/user/.active_character
huan-ui/user/config.json
huan-ui/user/current_character.txt
huan-ui/user/last_workspace.txt
huan-ui/user/workspaces.json
huan-ui/user/sessions/
huan-ui/user/workspace/

# Per-character runtime & secrets (keep only config.json, SOUL.md, frames/frame-0001.png)
huan-ui/user/characters/*/auth.json
huan-ui/user/characters/*/auth.lock
huan-ui/user/characters/*/config.yaml
huan-ui/user/characters/*/MEMORY.md
huan-ui/user/characters/*/USER.md
huan-ui/user/characters/*/gateway_state.json
